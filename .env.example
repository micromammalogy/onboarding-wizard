# =============================================================================
# Zonos Onboarding Wizard — Environment Variables
# =============================================================================
# Copy this file to .env.local for local dev, or add these in Vercel Dashboard
# under Settings → Environment Variables.
#
# All server-side variables (no NEXT_PUBLIC_ prefix) are secret and should
# never be exposed to the browser.
# =============================================================================

# --- Supabase (client-side, safe to expose) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Zonos GraphQL Endpoints (server-side only) ---
INTERNAL_GRAPH_URL=
VIEWPORT_GRAPH_URL=
AUTH_GRAPH_URL=
FRONTEND_GRAPH_URL=
INTERNAL_UPS_GRAPH_URL=          # optional

# --- Zonos Auth Tokens (server-side only) ---
AUTH_GRAPH_TOKEN=
INTERNAL_GRAPH_TOKEN=
FRONTEND_GRAPH_ADMIN_SECRET=
VIEWPORT_GRAPH_ADMIN_SECRET=
